# Render Dashboard -> Environment 中手动填入以下变量

# ===== 必填 =====
V2EX_COOKIE=<从浏览器 DevTools 复制的完整 Cookie 字符串>
TG_TOKEN=<BotFather 申请的 Bot Token>

# ===== 授权用户（二选一）=====
# 方式 A：直接填你的 Telegram 数字 Chat ID
# TG_CHAT_ID=<你的 Telegram 数字 Chat ID>
# 方式 B：不填 TG_CHAT_ID 时必须设置绑定口令，首次私聊 Bot 发送 /bind <口令>
# TG_SETUP_CODE=<自定义一次性绑定口令>

# ===== 可选 =====
# 多账号 profile 隔离
# V2EX_PROFILE=acc1

# 跳过阅读模块（仅运行签到+Bot，更省内存）
# SKIP_READER=1

# 本机代理（可选，默认关闭）：只允许 localhost / 127.0.0.1 / ::1，不支持远端代理
# V2EX_PROXY_ENABLE=1
# V2EX_PROXY=http://127.0.0.1:7890
# V2EX_PROXY=socks5://127.0.0.1:7890

# 时区
TZ=Asia/Shanghai
