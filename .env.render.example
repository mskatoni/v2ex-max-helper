# Render Dashboard -> Environment 中手动填入以下变量

# ===== 必填 =====
V2EX_COOKIE=<从浏览器 DevTools 复制的完整 Cookie 字符串>
TG_TOKEN=<BotFather 申请的 Bot Token>

# ===== 授权用户（二选一；Render 推荐方式 A）=====
# 方式 A：直接填你的 Telegram 数字 Chat ID；真实值只填 Render Dashboard，不要提交到仓库
# TG_CHAT_ID=<你的 Telegram 数字 Chat ID>
# 方式 B：临时绑定；免费实例重启后绑定文件会丢失，需要再次 /bind
# TG_SETUP_CODE=<自定义一次性绑定口令>

# ===== 可选 =====
# 多账号 profile 隔离
# 使用顶部 V2EX_COOKIE 初始化多账号时必须显式指定此项，且值必须包含在 PROFILE_LIST 中
# V2EX_PROFILE=acc1
# 多账号串行调度（可选）
# 最多 6 个 profile；名称不能仅大小写不同，全部固定窗口总长不得超过 24 小时
# V2EX_PROFILE_LIST=acc1,acc2
# PROFILE_TIME_SLOT_HOURS=4

# 跳过阅读模块（仅运行签到+Bot，更省内存）
# SKIP_READER=1

# 代理（可选，默认关闭）：代理软件不限定 mihomo，也可以是 xray-core、sing-box、Clash、Surge、gost 等
# HTTP(S) 可带账号密码；Playwright 浏览器仅支持无认证 SOCKS5
# Docker Compose 访问宿主机代理使用 host.docker.internal；Render 无法访问你本机的该地址
# V2EX_PROXY_ENABLE=1
# V2EX_PROXY_ALLOW_LAN=1
# V2EX_PROXY=http://host.docker.internal:7890
# V2EX_PROXY=socks5://host.docker.internal:7890
# HTTPS_PROXY=http://host.docker.internal:7890
# NO_PROXY=localhost,127.0.0.1

# 飞书（实验/社区讨论，默认关闭）
# FEISHU_ENABLE=1
# FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/你的KEY
# FEISHU_BOT_ENABLE=1
# FEISHU_APP_ID=<飞书应用App ID>
# FEISHU_APP_SECRET=<飞书应用App Secret>
# FEISHU_VERIFICATION_TOKEN=<飞书事件订阅校验token>
# FEISHU_CHAT_ID=<唯一授权飞书会话ID>
# FEISHU_BOT_PORT=6700

# 时区
TZ=Asia/Shanghai
