# V2EX Max Helper 配置示例
# 复制并编辑: cp .v2ex_env.example ~/.v2ex_env

# ===== 飞书 L1：Webhook 推送通知（简单，推荐）=====
# 飞书群 → 设置 → 群机器人 → 自定义机器人 → Webhook 地址
# 安全设置选「自定义关键词」，填：V2EX
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/你的webhook地址

# ===== 飞书 L2：应用机器人交互命令（可选，需额外配置）=====
# 详见 docs/飞书应用机器人配置.md
# FEISHU_APP_ID=cli_xxxxxxxxxxxx
# FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxx
# FEISHU_VERIFICATION_TOKEN=xxxxxxxxxxxxxxxx
# FEISHU_BOT_PORT=6700

# ===== Telegram Bot（可选，传统方式）=====
# TG_TOKEN=<BotToken>
# TG_CHAT_ID=<ChatID>

# ===== 阅读日志路径 =====
# READER_LOG=/var/log/v2ex-reader.log
